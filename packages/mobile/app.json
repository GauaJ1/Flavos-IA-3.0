{
  "expo": {
    "name": "Flavos IA",
    "slug": "flavos-ia",
    "version": "3.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "flavosia",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flavos.ia"
    },
    "android": {
      "package": "com.flavos.ia",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f"
      }
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
