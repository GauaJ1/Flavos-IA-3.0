# ===================================================
# Flavos IA 3.0 — Environment Variables
# ===================================================
# Copie este arquivo para .env e preencha os valores.

# Google Gemini API Key (obrigatório para o backend proxy)
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo do Gemini a ser utilizado
GEMINI_MODEL=gemini-3.1-flash

# Porta do backend proxy
PORT=3001

# URL do backend (usado pelo frontend)
VITE_API_URL=http://localhost:3001

# TODO: Firebase — Descomente quando integrar
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
