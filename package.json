{
  "name": "flavos-ia",
  "version": "3.0.0",
  "private": true,
  "description": "Flavos IA 3.0 — AI Chat powered by Gemini 3.1-flash",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@flavos/web",
    "dev:backend": "turbo run dev --filter=@flavos/backend",
    "dev:mobile": "turbo run dev --filter=@flavos/mobile",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0"
}
